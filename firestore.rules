rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function userRoles() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('roles', [])
        : [];
    }

    function hasRole(role) {
      return isAuth() && role in userRoles();
    }

    function isAdmin() {
      return hasRole('admin') || hasRole('operator');
    }

    function isDriver() {
      return hasRole('driver');
    }

    function isConductor() {
      return hasRole('conductor') || isAdmin();
    }

    // ── users ────────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read:   if isAuth();
      allow create: if isAuth() && (request.auth.uid == uid || isAdmin());
      allow update: if isAuth() && (request.auth.uid == uid || isAdmin());
      allow delete: if isAdmin();
    }

    // ── routes ───────────────────────────────────────────────────────────────
    match /routes/{routeId} {
      allow read:  if isAuth();
      allow write: if isAdmin();
    }

    // ── buses ────────────────────────────────────────────────────────────────
    // Students need to update buses to increment activeTicketCount when booking.
    // Students can also update occupiedSeats array when booking/cancelling.
    match /buses/{busId} {
      allow read: if isAuth();
      allow create: if isAdmin();
      allow delete: if isAdmin();
      allow update: if isAdmin()
        || (isDriver()
            && (resource.data.driverId == null
                || resource.data.driverId == request.auth.uid))
        // Students can only increment activeTicketCount (booking transaction)
        // or update occupiedSeats array (when booking/cancelling seats)
        || (isAuth()
            && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['activeTicketCount', 'occupiedSeats']));
    }

    // ── busGcash ─────────────────────────────────────────────────────────────
    match /busGcash/{busId} {
      allow read:  if isAuth();
      allow write: if isAdmin();
    }

    // ── tickets ──────────────────────────────────────────────────────────────
    // Students read their OWN tickets (needed for the userId== query in bookTicket).
    // Conductors, drivers, and admins can read all tickets.
    match /tickets/{ticketId} {
      allow read: if isAuth()
        && (resource.data.userId == request.auth.uid || isConductor() || isDriver() || isAdmin());
      allow create: if isAuth()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isAuth()
        && (resource.data.userId == request.auth.uid || isConductor() || isDriver());
      allow delete: if isAdmin()
        || (isAuth()
            && resource.data.userId == request.auth.uid
            && resource.data.status == 'completed');
    }

    // ── notifications ────────────────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read:   if isAuth() && resource.data.userId == request.auth.uid;
      // Students and staff can create notifications (booking confirmations,
      // boarding alerts written by the driver context, proximity alerts).
      allow create: if isAuth();
      allow update: if isAuth() && resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }
  }
}
